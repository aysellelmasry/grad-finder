# Backend Environment Variables

# File paths (can be local or absolute paths)
ENCODINGS_FILE=face_encodings.pkl
METADATA_FILE=photos_metadata.pkl
GDRIVE_FILE=gdrive_file_mappingf.json

# Face recognition tolerance (0-1, lower = stricter matching)
TOLERANCE=0.52

# Max upload file size in MB
MAX_UPLOAD_MB=16

# Comma-separated list of allowed origins for CORS
# Use * for development (allows all origins)
# For production, use specific domains: https://your-app.vercel.app,https://example.com
ALLOWED_ORIGINS=*

# Flask debug mode (only set to true in development)
FLASK_DEBUG=False

# Port (Replit will set this automatically)
# PORT=5000
